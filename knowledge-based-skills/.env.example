# Copy to .env and fill in. mise.toml supplies sane defaults for the
# non-secret values (FALKOR_*, ANTHROPIC_MODEL, FIRECRAWL_CONCURRENCY,
# EMBEDDING_MODEL); only the API keys live here.

# Required.
ANTHROPIC_API_KEY=sk-ant-...
FIRECRAWL_API_KEY=fc-...

# Optional overrides (uncomment to deviate from mise.toml).
# FALKOR_PORT=6379
# FALKOR_BROWSER_PORT=3000
# ANTHROPIC_MODEL=claude-sonnet-4-6
# FIRECRAWL_CONCURRENCY=5
